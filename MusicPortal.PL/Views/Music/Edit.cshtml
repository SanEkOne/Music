@model MusicPortal.BLL.DTO.MusicDTO

@{
    ViewBag.Title = "Редактировать трек";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-success text-white text-center py-3">
                    <h4 class="mb-0">📝 Редактирование трека</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit" method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <input type="hidden" asp-for="Id" />

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-bold">Название</label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Author" class="form-label fw-bold">Исполнитель</label>
                            <input asp-for="Author" class="form-control" />
                            <span asp-validation-for="Author" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Genre" class="form-label fw-bold">Жанр</label>
                            <select asp-for="Genre" class="form-select">
                                <option value="Pop">Pop</option>
                                <option value="Rock">Rock</option>
                                <option value="Hip-Hop">Hip-Hop</option>
                                <option value="Electronic">Electronic</option>
                            </select>
                            <span asp-validation-for="Genre" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold d-block">Заменить аудиофайл (необязательно)</label>
                            <input type="file" name="uploadedFile" class="form-control" accept="audio/*" />
                            <div class="form-text text-muted">Оставьте пустым, чтобы сохранить текущий файл.</div>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success">Сохранить изменения</button>
                            <a asp-action="Index" class="btn btn-link text-muted text-center">Отмена</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
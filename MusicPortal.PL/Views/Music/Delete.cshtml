@model MusicPortal.BLL.DTO.MusicDTO

@{
    ViewBag.Title = "Удаление трека";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-danger shadow-sm">
                <div class="card-header bg-danger text-white text-center py-3">
                    <h4 class="mb-0">⚠️ Подтверждение удаления</h4>
                </div>
                <div class="card-body p-4 text-center">
                    <p class="lead">Вы уверены, что хотите удалить этот трек?</p>

                    <div class="bg-light p-3 rounded mb-4">
                        <h5 class="mb-1">@Model.Name</h5>
                        <p class="text-muted mb-0">@Model.Author</p>
                        <span class="badge bg-secondary mt-2">@Model.Genre</span>
                    </div>

                    <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger">Да, удалить навсегда</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Отмена</a>
                        </div>
                    </form>
                </div>
            </div>
            <div class="text-center mt-3">
                <small class="text-muted">Это действие нельзя будет отменить.</small>
            </div>
        </div>
    </div>
</div>